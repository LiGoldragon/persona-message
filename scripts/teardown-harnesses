#!/usr/bin/env bash
set -euo pipefail

script_dir="${PERSONA_MESSAGE_SCRIPT_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}"
# shellcheck source=scripts/harness-common
source "$script_dir/harness-common"

root="$(harness_root "${1:-}")"
load_harness "$root"

wezterm cli --prefer-mux kill-pane --pane-id "$PERSONA_MESSAGE_OPERATOR_PANE" >/dev/null 2>&1 || true
wezterm cli --prefer-mux kill-pane --pane-id "$PERSONA_MESSAGE_DESIGNER_PANE" >/dev/null 2>&1 || true

echo "tore down harness workspace: $root"
