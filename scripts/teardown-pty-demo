#!/usr/bin/env bash
set -euo pipefail

root="${1:-${PERSONA_PTY_ROOT:-}}"
if [[ -z "$root" && -s /tmp/persona-pty-current ]]; then
  root="$(cat /tmp/persona-pty-current)"
fi
if [[ -z "$root" ]]; then
  echo "missing PTY demo root; pass one or run setup-pty-demo first" >&2
  exit 2
fi

source "$root/session.env"
kill "$PERSONA_PTY_DAEMON_PID" 2>/dev/null || true
echo "tore down PTY demo: $root"
