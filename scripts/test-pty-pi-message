#!/usr/bin/env bash
set -euo pipefail

repo="${PERSONA_MESSAGE_REPO:-$PWD}"
cd "$repo"
terminal_repo="${PERSONA_WEZTERM_REPO:-$(cd "$repo/../persona-wezterm" && pwd)}"
terminal_target="$terminal_repo/target/debug"

cleanup_root() {
  local root="$1"
  [[ -n "$root" && -d "$root" ]] || return 0
  for file in "$root"/*.daemon.pid "$root"/*.pid "$root"/*.viewer.pid; do
    [[ -f "$file" ]] || continue
    local pid
    pid="$(cat "$file" 2>/dev/null || true)"
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    kill "$pid" 2>/dev/null || true
  done
}

current_file="/tmp/persona-pty-pi-message-current"
if [[ -s "$current_file" ]]; then
  cleanup_root "$(cat "$current_file")"
fi

root="${PERSONA_PTY_PI_MESSAGE_ROOT:-$(mktemp -d -t persona-pty-pi-message.XXXXXXXX)}"
store="$root/store"
workspace="$root/workspace"
socket_a="$root/pi-a.sock"
socket_b="$root/pi-b.sock"
daemon_socket="$root/message.sock"
skill_file="${PERSONA_MESSAGE_HARNESS_SKILL:-$repo/skills/persona-message-harness.md}"
mkdir -p "$store" "$workspace" "$root/sessions"

cargo build --bin message
cargo build --manifest-path "$terminal_repo/Cargo.toml" --bins

pi_bin="${PERSONA_PI_BIN:-$(command -v pi)}"
pi_model="${PERSONA_PI_MODEL:-prometheus/qwen3.6-27b}"
pi_thinking="${PERSONA_PI_THINKING:-medium}"
runner_path="$repo/target/debug:$terminal_target:$PATH"

if [[ ! -f "$skill_file" ]]; then
  echo "missing Persona message harness skill: $skill_file" >&2
  exit 1
fi

start_agent() {
  local actor="$1"
  local socket="$2"
  local workspace_dir="$workspace/$actor"
  local runner="$root/run-$actor.sh"
  local pid_file="$root/$actor.pid"
  mkdir -p "$workspace_dir" "$root/sessions/$actor"
  cat > "$runner" <<EOF
#!/bin/sh
set -eu
cd '$workspace_dir'
printf '%s\n' \$\$ > '$pid_file'
export PERSONA_MESSAGE_STORE='$store'
export PERSONA_MESSAGE_DAEMON='$daemon_socket'
export PATH='$runner_path'
unset NO_COLOR
export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR=1
export FORCE_COLOR=1
export PI_CODING_AGENT_SESSION_DIR='$root/sessions/$actor'
exec '$pi_bin' --offline --model '$pi_model' --thinking '$pi_thinking' --tools bash --append-system-prompt '$skill_file' --no-skills --no-context-files
EOF
  chmod +x "$runner"

  setsid "$terminal_target/persona-wezterm-daemon" "$socket" "$runner" >"$root/$actor.daemon.log" 2>&1 &
  local daemon_pid="$!"
  printf '%s\n' "$daemon_pid" > "$root/$actor.daemon.pid"
  for _ in $(seq 1 120); do
    [[ -S "$socket" ]] && break
    sleep 0.1
  done
  if [[ ! -S "$socket" ]]; then
    echo "Pi PTY daemon did not create socket for $actor: $socket" >&2
    sed -n '1,160p' "$root/$actor.daemon.log" >&2 || true
    exit 1
  fi
  for _ in $(seq 1 200); do
    [[ -s "$pid_file" ]] && break
    sleep 0.1
  done
  if [[ ! -s "$pid_file" ]]; then
    echo "missing Pi harness pid file for $actor: $pid_file" >&2
    exit 1
  fi
}

start_viewer() {
  local actor="$1"
  local socket="$2"
  setsid wezterm start \
    --always-new-process \
    --class "persona-pty-pi-message-$actor" \
    --workspace persona-pty-pi-message \
    --cwd "$root" \
    -- env PERSONA_WEZTERM_HANDSHAKE=1 PERSONA_WEZTERM_VIEW_TITLE="PERSONA-$actor" "$terminal_target/persona-wezterm-view" "$socket" >"$root/$actor.viewer.log" 2>&1 &
  printf '%s\n' "$!" > "$root/$actor.viewer.pid"
}

send_prompt() {
  local socket="$1"
  local text="$2"
  "$terminal_target/persona-wezterm-send" "$socket" "$text"
}

wait_for_log() {
  local needle="$1"
  local timeout="$2"
  local deadline=$((SECONDS + timeout))
  while (( SECONDS < deadline )); do
    if [[ -f "$store/messages.nota.log" ]] && rg -q --fixed-strings "$needle" "$store/messages.nota.log"; then
      return 0
    fi
    sleep 1
  done
  echo "timed out waiting for message log text: $needle" >&2
  echo "root=$root" >&2
  echo "--- messages.nota.log ---" >&2
  sed -n '1,200p' "$store/messages.nota.log" >&2 || true
  echo "--- initiator daemon log ---" >&2
  sed -n '1,120p' "$root/initiator.daemon.log" >&2 || true
  echo "--- responder daemon log ---" >&2
  sed -n '1,120p' "$root/responder.daemon.log" >&2 || true
  return 1
}

wait_for_message() {
  local from="$1"
  local to="$2"
  local body="$3"
  local timeout="$4"
  local deadline=$((SECONDS + timeout))
  while (( SECONDS < deadline )); do
    if [[ -f "$store/messages.nota.log" ]] \
      && rg -q --fixed-strings "$from" "$store/messages.nota.log" \
      && rg -q --fixed-strings "$to" "$store/messages.nota.log" \
      && rg -q --fixed-strings "$body" "$store/messages.nota.log"; then
      return 0
    fi
    sleep 1
  done
  echo "timed out waiting for message $from -> $to: $body" >&2
  echo "root=$root" >&2
  echo "--- messages.nota.log ---" >&2
  sed -n '1,200p' "$store/messages.nota.log" >&2 || true
  return 1
}

start_agent initiator "$socket_a"
start_agent responder "$socket_b"

pid_a="$(cat "$root/initiator.pid")"
pid_b="$(cat "$root/responder.pid")"
operator_pane="${PERSONA_OPERATOR_PANE_ID:-${WEZTERM_PANE:-None}}"
operator_socket="${WEZTERM_UNIX_SOCKET:-None}"
if [[ "$operator_pane" =~ ^[0-9]+$ && "$operator_socket" != None ]]; then
  operator_endpoint="(EndpointTransport wezterm-pane \"$operator_pane\" \"$operator_socket\")"
elif [[ "$operator_pane" =~ ^[0-9]+$ ]]; then
  operator_endpoint="(EndpointTransport wezterm-pane \"$operator_pane\" None)"
else
  operator_endpoint="None"
fi
cat > "$store/actors.nota" <<EOF
(Actor operator $$ $operator_endpoint)
(Actor initiator $pid_a (EndpointTransport pty-socket "$socket_a" None))
(Actor responder $pid_b (EndpointTransport pty-socket "$socket_b" None))
EOF

setsid "$repo/target/debug/message-daemon" "$daemon_socket" >"$root/message-daemon.log" 2>&1 &
printf '%s\n' "$!" > "$root/message-daemon.pid"
for _ in $(seq 1 120); do
  [[ -S "$daemon_socket" ]] && break
  sleep 0.1
done
if [[ ! -S "$daemon_socket" ]]; then
  echo "message daemon did not create socket: $daemon_socket" >&2
  sed -n '1,160p' "$root/message-daemon.log" >&2 || true
  exit 1
fi

cat > "$root/session.env" <<EOF
PERSONA_PTY_PI_MESSAGE_ROOT=$root
PERSONA_MESSAGE_STORE=$store
PERSONA_MESSAGE_DAEMON=$daemon_socket
PERSONA_INITIATOR_SOCKET=$socket_a
PERSONA_RESPONDER_SOCKET=$socket_b
PERSONA_INITIATOR_PID=$pid_a
PERSONA_RESPONDER_PID=$pid_b
PERSONA_OPERATOR_PANE_ID=$operator_pane
WEZTERM_UNIX_SOCKET=$operator_socket
PERSONA_PI_MODEL=$pi_model
PERSONA_PI_THINKING=$pi_thinking
PERSONA_MESSAGE_HARNESS_SKILL=$skill_file
PERSONA_WEZTERM_HANDSHAKE=1
EOF
printf '%s\n' "$root" > "$current_file"

if [[ "${PERSONA_PI_TEST_VISIBLE:-1}" != 0 ]]; then
  start_viewer initiator "$socket_a"
  start_viewer responder "$socket_b"
fi

sleep 5
responder_ready="responder-ready"
initiator_ready="initiator-ready"
request_body="please reply to the sender with reply"
reply_body="reply"
received_body="received-reply"

send_prompt "$socket_b" "You are responder, a Persona harness. Read the Persona Message Harness skill loaded from $skill_file and follow it. Report readiness to operator with a Persona message whose body is $responder_ready, then leave the harness idle so later terminal input can wake you."

wait_for_message "responder" "operator" "$responder_ready" "${PERSONA_PI_TEST_TIMEOUT:-240}"

sleep 2
send_prompt "$socket_a" "You are initiator, a Persona harness. Read the Persona Message Harness skill loaded from $skill_file and follow it. Report readiness to operator with a Persona message whose body is $initiator_ready, then leave the harness idle so later terminal input can wake you."

wait_for_message "initiator" "operator" "$initiator_ready" "${PERSONA_PI_TEST_TIMEOUT:-240}"

PERSONA_MESSAGE_STORE="$store" PERSONA_MESSAGE_DAEMON="$daemon_socket" "$repo/target/debug/message" "(Send initiator \"send responder a Persona message with exactly this body: $request_body. When you receive $reply_body from responder, report $received_body to operator.\")"
wait_for_message "initiator" "responder" "$request_body" "${PERSONA_PI_TEST_TIMEOUT:-240}"
wait_for_message "responder" "initiator" "$reply_body" "${PERSONA_PI_TEST_TIMEOUT:-240}"
wait_for_message "initiator" "operator" "$received_body" "${PERSONA_PI_TEST_TIMEOUT:-240}"

echo "pi_pair_message_test=passed"
echo "root=$root"
echo "store=$store"
echo "initiator_pid=$pid_a"
echo "responder_pid=$pid_b"
echo "model=$pi_model"
echo "thinking=$pi_thinking"
echo "message_log=$store/messages.nota.log"
echo "teardown: PERSONA_PTY_PI_MESSAGE_ROOT=$root nix run .#teardown-pty-pi-message"
