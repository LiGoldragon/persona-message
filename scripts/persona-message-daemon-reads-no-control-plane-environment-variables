#!/usr/bin/env bash
set -euo pipefail

root="${1:?repository root required}"

if rg 'std::env::|env::var|var_os\(' \
  "$root/src/bin/persona_message_daemon.rs" \
  "$root/src/daemon.rs"
then
  printf 'persona-message-daemon must read typed argv configuration, not control-plane environment variables.\n' >&2
  exit 1
fi
