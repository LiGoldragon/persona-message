#!/usr/bin/env bash
set -euo pipefail

source_root="${1:?usage: message-runtime-cannot-reference-retired-terminal-brand <source-root>}"

if rg --line-number \
  --glob 'Cargo.toml' \
  --glob 'Cargo.lock' \
  --glob 'flake.nix' \
  --glob 'src/**' \
  --glob 'tests/**' \
  --glob 'scripts/**' \
  --glob '!scripts/message-runtime-cannot-reference-retired-terminal-brand' \
  'WezTerm|wezterm|WEZTERM|persona-wezterm|persona_wezterm|WezTermPane' \
  "$source_root"
then
  echo "active persona-message runtime still references retired terminal-brand infrastructure" >&2
  exit 1
fi
