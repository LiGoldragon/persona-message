#!/usr/bin/env bash
set -euo pipefail

mode="${1:-visible}"
case "$mode" in
  visible|headless) ;;
  *)
    echo "usage: setup-harnesses [visible|headless]" >&2
    exit 2
    ;;
esac

repo="${PERSONA_MESSAGE_REPO:-$PWD}"
cd "$repo"

codex_model="${PERSONA_CODEX_MODEL:-gpt-5.4-mini}"
claude_model="${PERSONA_CLAUDE_MODEL:-claude-haiku-4-5}"
codex_bin="${PERSONA_CODEX_BIN:-$(command -v codex)}"
claude_bin="${PERSONA_CLAUDE_BIN:-$(command -v claude)}"
workspace="${PERSONA_MESSAGE_HARNESS_ROOT:-$(mktemp -d -t persona-message-harnesses.XXXXXXXX)}"
store="$workspace/store"
worktree="$workspace/workspace"
mkdir -p "$store" "$worktree/operator" "$worktree/designer"

message_bin_dir="$repo/target/debug"
if [[ ! -x "$message_bin_dir/message" ]]; then
  cargo build --bin message
fi

runner_path="$message_bin_dir:$PATH"
operator_prompt="You are the operator Persona harness. The command line tool named message is on PATH. Persona messages are NOTA records. To send one, run: message '(Send designer \"hello\")'. To read your inbox, run: message '(Inbox operator)'. When terminal input contains an incoming (Message ...) NOTA record addressed to operator whose body begins with REPLY_REQUEST:, read its from field and reply by running message '(Send <from> \"REPLY_RESPONSE:ack from operator\")'. Do not auto-reply to REPLY_RESPONSE messages. Reply with OPERATOR READY, then wait idle for later terminal input."
designer_prompt="You are the designer Persona harness. The command line tool named message is on PATH. Persona messages are NOTA records. To send one, run: message '(Send operator \"hello\")'. To read your inbox, run: message '(Inbox designer)'. When terminal input contains an incoming (Message ...) NOTA record addressed to designer whose body begins with REPLY_REQUEST:, read its from field and reply by running message '(Send <from> \"REPLY_RESPONSE:ack from designer\")'. Do not auto-reply to REPLY_RESPONSE messages. Reply with DESIGNER READY, then wait idle for later terminal input."

quote() {
  printf "'%s'" "${1//\'/\'\\\'\'}"
}

write_runner() {
  local actor="$1"
  local program="$2"
  local command_body="$3"
  local runner="$workspace/run-$actor.sh"
cat > "$runner" <<EOF
#!/bin/sh
set -eu
printf '%s\n' \$\$ > $(quote "$workspace/$actor.pid")
export PERSONA_MESSAGE_STORE=$(quote "$store")
export PATH=$(quote "$runner_path")
unset NO_COLOR
export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR=1
export FORCE_COLOR=1
command -v $program >/dev/null
$command_body
EOF
  chmod +x "$runner"
}

write_runner "operator" "$codex_bin" "exec $(quote "$codex_bin") \\
  --dangerously-bypass-approvals-and-sandbox \\
  --model $(quote "$codex_model") \\
  -c $(quote 'model_reasoning_effort="low"') \\
  --cd $(quote "$worktree/operator")"

write_runner "designer" "$claude_bin" "exec $(quote "$claude_bin") \\
  --model $(quote "$claude_model") \\
  --effort low \\
  --dangerously-skip-permissions \\
  --add-dir $(quote "$worktree/designer")"

spawn_pane() {
  local actor="$1"
  local runner="$workspace/run-$actor.sh"
  wezterm cli --prefer-mux spawn \
    --new-window \
    --workspace "persona-message-$mode" \
    --cwd "$worktree" \
    -- sh -lc "exec $(quote "$runner")"
}

nudge_pane() {
  local pane="$1"
  local text="$2"
  wezterm cli --prefer-mux send-text --pane-id "$pane" "$text"
  sleep 0.5
  wezterm cli --prefer-mux send-text --pane-id "$pane" --no-paste "$(printf '\r')"
}

operator_pane="$(spawn_pane operator)"
designer_pane="$(spawn_pane designer)"

wait_pid() {
  local path="$1"
  local deadline=$((SECONDS + 20))
  while (( SECONDS < deadline )); do
    if [[ -s "$path" ]]; then
      cat "$path"
      return 0
    fi
    sleep 0.1
  done
  echo "missing pid file: $path" >&2
  return 1
}

operator_pid="$(wait_pid "$workspace/operator.pid")"
designer_pid="$(wait_pid "$workspace/designer.pid")"

wezterm_socket="${WEZTERM_UNIX_SOCKET:-None}"
if [[ "$wezterm_socket" == None ]]; then
  operator_endpoint="(EndpointTransport wezterm-pane \"$operator_pane\" None)"
  designer_endpoint="(EndpointTransport wezterm-pane \"$designer_pane\" None)"
else
  operator_endpoint="(EndpointTransport wezterm-pane \"$operator_pane\" \"$wezterm_socket\")"
  designer_endpoint="(EndpointTransport wezterm-pane \"$designer_pane\" \"$wezterm_socket\")"
fi

cat > "$store/actors.nota" <<EOF
(Actor operator $operator_pid $operator_endpoint)
(Actor designer $designer_pid $designer_endpoint)
EOF

sleep 2
nudge_pane "$operator_pane" "$operator_prompt"
nudge_pane "$designer_pane" "$designer_prompt"

gui_process="none"
if [[ "$mode" == "visible" ]]; then
  gui_log="$workspace/wezterm-gui.log"
  wezterm connect local \
    --workspace "persona-message-visible" >"$gui_log" 2>&1 &
  gui_process="$!"
fi

cat > "$workspace/README.txt" <<EOF
Persona message harness setup

mode: $mode
workspace: $workspace
store: $store
operator pane: $operator_pane
designer pane: $designer_pane
gui process: $gui_process
operator pid: $operator_pid
designer pid: $designer_pid

Useful commands:
  PERSONA_MESSAGE_STORE=$store message '(Send designer "hello")'
  PERSONA_MESSAGE_STORE=$store message '(Inbox designer)'

WezTerm capture:
  wezterm cli --prefer-mux get-text --pane-id $operator_pane
  wezterm cli --prefer-mux get-text --pane-id $designer_pane
EOF

cat > "$workspace/session.env" <<EOF
PERSONA_MESSAGE_HARNESS_ROOT=$workspace
PERSONA_MESSAGE_STORE=$store
PERSONA_MESSAGE_OPERATOR_PANE=$operator_pane
PERSONA_MESSAGE_DESIGNER_PANE=$designer_pane
PERSONA_MESSAGE_OPERATOR_PID=$operator_pid
PERSONA_MESSAGE_DESIGNER_PID=$designer_pid
PERSONA_MESSAGE_WEZTERM_WORKSPACE=persona-message-$mode
EOF

printf '%s\n' "$workspace" > /tmp/persona-message-current

echo "workspace=$workspace"
echo "store=$store"
echo "operator_pane=$operator_pane"
echo "designer_pane=$designer_pane"
echo "gui_process=$gui_process"
echo "operator_pid=$operator_pid"
echo "designer_pid=$designer_pid"
echo "actors=$store/actors.nota"
