#!/usr/bin/env bash
set -euo pipefail

script_dir="${PERSONA_MESSAGE_SCRIPT_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}"
# shellcheck source=scripts/harness-common
source "$script_dir/harness-common"

root="$(harness_root "${1:-}")"
load_harness "$root"

require_alive operator "$PERSONA_MESSAGE_OPERATOR_PID"
require_alive designer "$PERSONA_MESSAGE_DESIGNER_PID"

message_bin="${PERSONA_MESSAGE_REPO:-$PWD}/target/debug/message"
if [[ ! -x "$message_bin" ]]; then
  cargo build --bin message
fi

stamp="$(date +%s)"
request="REPLY_REQUEST:REUSE-${stamp}"
response="REPLY_RESPONSE:ack from designer"
log="$PERSONA_MESSAGE_STORE/messages.nota.log"

before_count=0
if [[ -f "$log" ]]; then
  before_count="$(wc -l < "$log" | tr -d ' ')"
fi

send_prompt "$PERSONA_MESSAGE_OPERATOR_PANE" \
  "Run this exact command: message '(Send designer \"$request\")'. Then wait for the designer reply. Do not send any further messages after a REPLY_RESPONSE arrives; just say REUSE-TEST-DONE."

deadline=$((SECONDS + 180))
while (( SECONDS < deadline )); do
  if [[ -f "$log" ]] && tail -n +"$((before_count + 1))" "$log" | rg -q "$response"; then
    break
  fi
  sleep 1
done

if [[ ! -f "$log" ]] || ! tail -n +"$((before_count + 1))" "$log" | rg -q "$response"; then
  echo "timed out waiting for response: $response" >&2
  echo "new log lines:" >&2
  tail -n +"$((before_count + 1))" "$log" >&2 || true
  exit 1
fi

operator_text="$(wezterm cli --prefer-mux get-text --pane-id "$PERSONA_MESSAGE_OPERATOR_PANE")"
designer_text="$(wezterm cli --prefer-mux get-text --pane-id "$PERSONA_MESSAGE_DESIGNER_PANE")"

if ! printf '%s' "$designer_text" | rg -q "$request"; then
  echo "designer display does not show request: $request" >&2
  exit 1
fi

if ! printf '%s' "$operator_text" | rg -q "$response"; then
  echo "operator display does not show response: $response" >&2
  exit 1
fi

echo "reuse test passed"
echo "workspace=$root"
echo "operator_pane=$PERSONA_MESSAGE_OPERATOR_PANE"
echo "designer_pane=$PERSONA_MESSAGE_DESIGNER_PANE"
echo "new_messages:"
tail -n +"$((before_count + 1))" "$log"
