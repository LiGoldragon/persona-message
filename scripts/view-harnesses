#!/usr/bin/env bash
set -euo pipefail

script_dir="${PERSONA_MESSAGE_SCRIPT_DIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}"
# shellcheck source=scripts/harness-common
source "$script_dir/harness-common"

root="$(harness_root "${1:-}")"
load_harness "$root"

require_alive operator "$PERSONA_MESSAGE_OPERATOR_PID"
require_alive designer "$PERSONA_MESSAGE_DESIGNER_PID"

viewer_loop() {
  local title="$1"
  local pane="$2"
  printf 'last=""; printf "\\033]0;%s\\007"; while true; do text="$(env -u WEZTERM_UNIX_SOCKET -u WEZTERM_PANE wezterm cli --prefer-mux get-text --escapes --pane-id %s 2>&1)"; if [ "$text" != "$last" ]; then printf "\\033[H"; printf "%%s\\n" "$text"; last="$text"; fi; sleep 1; done' "$title" "$pane"
}

operator_loop="$(viewer_loop PERSONA-OPERATOR-CODEX "$PERSONA_MESSAGE_OPERATOR_PANE")"
designer_loop="$(viewer_loop PERSONA-DESIGNER-CLAUDE "$PERSONA_MESSAGE_DESIGNER_PANE")"

wezterm start \
  --always-new-process \
  --class persona-message-viewer \
  --workspace persona-message-viewer \
  --cwd "$root" \
  -- bash -lc "$operator_loop" >/tmp/persona-message-viewer-operator.log 2>&1 &
operator_viewer="$!"

wezterm start \
  --always-new-process \
  --class persona-message-viewer \
  --workspace persona-message-viewer \
  --cwd "$root" \
  -- bash -lc "$designer_loop" >/tmp/persona-message-viewer-designer.log 2>&1 &
designer_viewer="$!"

echo "viewer_operator_process=$operator_viewer"
echo "viewer_designer_process=$designer_viewer"
echo "operator_pane=$PERSONA_MESSAGE_OPERATOR_PANE"
echo "designer_pane=$PERSONA_MESSAGE_DESIGNER_PANE"
echo "workspace=$root"
