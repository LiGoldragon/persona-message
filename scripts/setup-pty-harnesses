#!/usr/bin/env bash
set -euo pipefail

repo="${PERSONA_MESSAGE_REPO:-$PWD}"
cd "$repo"
terminal_repo="${PERSONA_WEZTERM_REPO:-$(cd "$repo/../persona-wezterm" && pwd)}"
terminal_target="$terminal_repo/target/debug"

root="${PERSONA_PTY_HARNESS_ROOT:-$(mktemp -d -t persona-pty-harnesses.XXXXXXXX)}"
store="$root/store"
workspace="$root/workspace"
mkdir -p "$store" "$workspace/operator" "$workspace/designer"

cargo build --bin message
cargo build --manifest-path "$terminal_repo/Cargo.toml" --bins

codex_model="${PERSONA_CODEX_MODEL:-gpt-5.4-mini}"
claude_model="${PERSONA_CLAUDE_MODEL:-claude-haiku-4-5}"
codex_bin="${PERSONA_CODEX_BIN:-$(command -v codex)}"
claude_bin="${PERSONA_CLAUDE_BIN:-$(command -v claude)}"
runner_path="$repo/target/debug:$terminal_target:$PATH"

write_runner() {
  local actor="$1"
  local program="$2"
  local command_body="$3"
  local runner="$root/run-$actor.sh"
cat > "$runner" <<EOF
#!/bin/sh
set -eu
cd '$workspace/$actor'
printf '%s\n' \$\$ > '$root/$actor.pid'
export PERSONA_MESSAGE_STORE='$store'
export PATH='$runner_path'
unset NO_COLOR
export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR=1
export FORCE_COLOR=1
command -v $program >/dev/null
$command_body
EOF
  chmod +x "$runner"
}

write_runner "operator" "$codex_bin" "exec '$codex_bin' \\
  --dangerously-bypass-approvals-and-sandbox \\
  --no-alt-screen \\
  --model '$codex_model' \\
  -c 'model_reasoning_effort=\"low\"' \\
  --cd '$workspace/operator'"

write_runner "designer" "$claude_bin" "exec '$claude_bin' \\
  --model '$claude_model' \\
  --name designer-claude \\
  --effort low \\
  --dangerously-skip-permissions \\
  --add-dir '$workspace/designer'"

start_agent() {
  local actor="$1"
  local socket="$root/$actor.sock"
  setsid "$terminal_target/persona-wezterm-daemon" "$socket" "$root/run-$actor.sh" >"$root/$actor.ptyd.log" 2>&1 &
  local daemon_pid="$!"
  for _ in $(seq 1 100); do
    [[ -S "$socket" ]] && break
    sleep 0.1
  done
  if [[ ! -S "$socket" ]]; then
    echo "$actor PTY daemon did not create socket: $socket" >&2
    sed -n '1,120p' "$root/$actor.ptyd.log" >&2 || true
    exit 1
  fi
  printf '%s\n' "$daemon_pid" > "$root/$actor.daemon.pid"
}

start_agent operator
start_agent designer

wait_pid() {
  local path="$1"
  for _ in $(seq 1 200); do
    if [[ -s "$path" ]]; then
      cat "$path"
      return 0
    fi
    sleep 0.1
  done
  echo "missing pid file: $path" >&2
  return 1
}

operator_pid="$(wait_pid "$root/operator.pid")"
designer_pid="$(wait_pid "$root/designer.pid")"

cat > "$store/actors.nota" <<EOF
(Actor operator $operator_pid (EndpointTransport PtySocket "$root/operator.sock" None))
(Actor designer $designer_pid (EndpointTransport PtySocket "$root/designer.sock" None))
EOF

cat > "$root/session.env" <<EOF
PERSONA_PTY_HARNESS_ROOT=$root
PERSONA_MESSAGE_STORE=$store
PERSONA_OPERATOR_SOCKET=$root/operator.sock
PERSONA_DESIGNER_SOCKET=$root/designer.sock
PERSONA_OPERATOR_DAEMON_PID=$(cat "$root/operator.daemon.pid")
PERSONA_DESIGNER_DAEMON_PID=$(cat "$root/designer.daemon.pid")
PERSONA_OPERATOR_PID=$operator_pid
PERSONA_DESIGNER_PID=$designer_pid
PERSONA_WEZTERM_HANDSHAKE=1
EOF
printf '%s\n' "$root" > /tmp/persona-pty-harnesses-current

setsid wezterm start \
  --always-new-process \
  --class persona-pty-harness \
  --workspace persona-pty-harness \
  --cwd "$root" \
  -- env PERSONA_WEZTERM_HANDSHAKE=1 PERSONA_WEZTERM_VIEW_TITLE=PERSONA-OPERATOR-CODEX "$terminal_target/persona-wezterm-view" "$root/operator.sock" >"$root/operator.view.log" 2>&1 &
operator_viewer="$!"

setsid wezterm start \
  --always-new-process \
  --class persona-pty-harness \
  --workspace persona-pty-harness \
  --cwd "$root" \
  -- env PERSONA_WEZTERM_HANDSHAKE=1 PERSONA_WEZTERM_VIEW_TITLE=PERSONA-DESIGNER-CLAUDE "$terminal_target/persona-wezterm-view" "$root/designer.sock" >"$root/designer.view.log" 2>&1 &
designer_viewer="$!"

echo "root=$root"
echo "store=$store"
echo "operator_socket=$root/operator.sock"
echo "designer_socket=$root/designer.sock"
echo "operator_pid=$operator_pid"
echo "designer_pid=$designer_pid"
echo "operator_daemon_pid=$(cat "$root/operator.daemon.pid")"
echo "designer_daemon_pid=$(cat "$root/designer.daemon.pid")"
echo "operator_viewer_pid=$operator_viewer"
echo "designer_viewer_pid=$designer_viewer"

sleep 6
"$repo/scripts/pty-send" "$root/designer.sock" ""
sleep 1
operator_prompt='You are the operator Persona harness in a Persona-owned PTY test. The command line tool message is on PATH. Reply OPERATOR PTY READY and then wait idle.'
designer_prompt='You are the designer Persona harness in a Persona-owned PTY test. The command line tool message is on PATH. Reply DESIGNER PTY READY and then wait idle.'
"$repo/scripts/pty-send" "$root/operator.sock" "$operator_prompt"
"$repo/scripts/pty-send" "$root/designer.sock" "$designer_prompt"
