#!/usr/bin/env bash
set -euo pipefail

repo="${PERSONA_MESSAGE_REPO:-$PWD}"
cd "$repo"
terminal_repo="${PERSONA_WEZTERM_REPO:-$(cd "$repo/../persona-wezterm" && pwd)}"
terminal_target="$terminal_repo/target/debug"

root="${PERSONA_PTY_ROOT:-$(mktemp -d -t persona-pty-demo.XXXXXXXX)}"
socket="$root/session.sock"
mkdir -p "$root"

cargo build --manifest-path "$terminal_repo/Cargo.toml" --bins

command=("${@:-${SHELL:-bash}}")
if [[ $# -eq 0 ]]; then
  command=("${SHELL:-bash}")
fi

setsid "$terminal_target/persona-wezterm-daemon" "$socket" "${command[@]}" >"$root/ptyd.log" 2>&1 &
daemon_pid="$!"

for _ in $(seq 1 100); do
  [[ -S "$socket" ]] && break
  sleep 0.1
done

if [[ ! -S "$socket" ]]; then
  echo "PTY daemon did not create socket: $socket" >&2
  sed -n '1,120p' "$root/ptyd.log" >&2 || true
  exit 1
fi

cat > "$root/session.env" <<EOF
PERSONA_PTY_ROOT=$root
PERSONA_PTY_SOCKET=$socket
PERSONA_PTY_DAEMON_PID=$daemon_pid
PERSONA_WEZTERM_HANDSHAKE=1
EOF
printf '%s\n' "$root" > /tmp/persona-pty-current

setsid wezterm start \
  --always-new-process \
  --class persona-pty-demo \
  --workspace persona-pty-demo \
  --cwd "$root" \
  -- env PERSONA_WEZTERM_HANDSHAKE=1 "$terminal_target/persona-wezterm-view" "$socket" >"$root/view.log" 2>&1 &
viewer_pid="$!"

echo "root=$root"
echo "socket=$socket"
echo "daemon_pid=$daemon_pid"
echo "viewer_pid=$viewer_pid"
echo "command=${command[*]}"
