#!/usr/bin/env bash
set -euo pipefail

repo="${PERSONA_MESSAGE_REPO:-$PWD}"
cd "$repo"
terminal_repo="${PERSONA_WEZTERM_REPO:-$(cd "$repo/../persona-wezterm" && pwd)}"
system_repo="${PERSONA_SYSTEM_REPO:-$(cd "$repo/../persona-system" && pwd)}"
terminal_target="$terminal_repo/target/debug"
system_bin="${PERSONA_SYSTEM_BIN:-$system_repo/target/debug/system}"

cleanup_root() {
  local root="$1"
  [[ -n "$root" && -d "$root" ]] || return 0
  for file in "$root"/*.daemon.pid "$root"/*.pid "$root"/*.viewer.pid "$root"/*.focus.pid; do
    [[ -f "$file" ]] || continue
    local pid
    pid="$(cat "$file" 2>/dev/null || true)"
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    kill "$pid" 2>/dev/null || true
  done
}

current_file="/tmp/persona-pty-pi-message-current"
if [[ -s "$current_file" && "${PERSONA_PI_FOCUS_KEEP_OLD:-0}" == 0 ]]; then
  cleanup_root "$(cat "$current_file")"
fi

root="${PERSONA_PTY_PI_MESSAGE_ROOT:-$(mktemp -d -t persona-pty-pi-focus.XXXXXXXX)}"
store="$root/store"
workspace="$root/workspace"
socket_a="$root/initiator.sock"
socket_b="$root/responder.sock"
mkdir -p "$store" "$workspace" "$root/sessions"

cargo build --bin message
cargo build --manifest-path "$terminal_repo/Cargo.toml" --bins
if [[ ! -x "$system_bin" ]]; then
  cargo build --manifest-path "$system_repo/Cargo.toml" --bin system
fi

pi_bin="${PERSONA_PI_BIN:-$(command -v pi)}"
pi_model="${PERSONA_PI_MODEL:-prometheus/qwen3.6-27b}"
pi_thinking="${PERSONA_PI_THINKING:-medium}"
runner_path="$repo/target/debug:$terminal_target:$PATH"

start_agent() {
  local actor="$1"
  local socket="$2"
  local workspace_dir="$workspace/$actor"
  local runner="$root/run-$actor.sh"
  local pid_file="$root/$actor.pid"
  mkdir -p "$workspace_dir" "$root/sessions/$actor"
  cat > "$runner" <<EOF
#!/bin/sh
set -eu
cd '$workspace_dir'
printf '%s\n' \$\$ > '$pid_file'
export PERSONA_MESSAGE_STORE='$store'
export PATH='$runner_path'
unset NO_COLOR
export TERM=xterm-256color
export COLORTERM=truecolor
export CLICOLOR=1
export FORCE_COLOR=1
export PI_CODING_AGENT_SESSION_DIR='$root/sessions/$actor'
exec '$pi_bin' --offline --model '$pi_model' --thinking '$pi_thinking' --tools bash --no-skills --no-context-files
EOF
  chmod +x "$runner"

  setsid "$terminal_target/persona-wezterm-daemon" "$socket" "$runner" >"$root/$actor.daemon.log" 2>&1 &
  local daemon_pid="$!"
  printf '%s\n' "$daemon_pid" > "$root/$actor.daemon.pid"
  for _ in $(seq 1 120); do
    [[ -S "$socket" ]] && break
    sleep 0.1
  done
  if [[ ! -S "$socket" ]]; then
    echo "Pi PTY daemon did not create socket for $actor: $socket" >&2
    sed -n '1,160p' "$root/$actor.daemon.log" >&2 || true
    exit 1
  fi
  for _ in $(seq 1 200); do
    [[ -s "$pid_file" ]] && break
    sleep 0.1
  done
  if [[ ! -s "$pid_file" ]]; then
    echo "missing Pi harness pid file for $actor: $pid_file" >&2
    exit 1
  fi
}

start_viewer() {
  local actor="$1"
  local socket="$2"
  local class="persona-pty-pi-focus-$actor"
  setsid wezterm start \
    --always-new-process \
    --class "$class" \
    --workspace persona-pty-pi-focus \
    --cwd "$root" \
    -- env PERSONA_WEZTERM_HANDSHAKE=1 PERSONA_WEZTERM_VIEW_TITLE="PERSONA-$actor" "$terminal_target/persona-wezterm-view" "$socket" >"$root/$actor.viewer.log" 2>&1 &
  printf '%s\n' "$!" > "$root/$actor.viewer.pid"
}

window_id_for_app_id() {
  local app_id="$1"
  python3 - "$app_id" <<'PY'
import json
import subprocess
import sys
import time

app_id = sys.argv[1]
for _ in range(100):
    data = json.loads(subprocess.check_output(["niri", "msg", "--json", "windows"]))
    matches = [window for window in data if window.get("app_id") == app_id]
    if matches:
        print(matches[-1]["id"])
        raise SystemExit(0)
    time.sleep(0.1)
raise SystemExit(f"no niri window for app_id={app_id}")
PY
}

observe_focus() {
  local actor="$1"
  local window_id="$2"
  "$system_bin" "(ObserveFocus (NiriWindow $window_id))" | tee "$root/$actor.focus.initial"
}

subscribe_focus() {
  local actor="$1"
  local window_id="$2"
  timeout "${PERSONA_PI_FOCUS_SUBSCRIBE_SECONDS:-8}" "$system_bin" "(SubscribeFocus (NiriWindow $window_id))" >"$root/$actor.focus.log" 2>"$root/$actor.focus.err" &
  printf '%s\n' "$!" > "$root/$actor.focus.pid"
}

send_prompt() {
  local socket="$1"
  local text="$2"
  "$terminal_target/persona-wezterm-send" "$socket" "$text"
}

start_agent initiator "$socket_a"
start_agent responder "$socket_b"
start_viewer initiator "$socket_a"
start_viewer responder "$socket_b"

initiator_pid="$(cat "$root/initiator.pid")"
responder_pid="$(cat "$root/responder.pid")"
cat > "$store/actors.nota" <<EOF
(Actor initiator $initiator_pid (EndpointTransport pty-socket "$socket_a" None))
(Actor responder $responder_pid (EndpointTransport pty-socket "$socket_b" None))
EOF

cat > "$root/session.env" <<EOF
PERSONA_PTY_PI_MESSAGE_ROOT=$root
PERSONA_MESSAGE_STORE=$store
PERSONA_INITIATOR_SOCKET=$socket_a
PERSONA_RESPONDER_SOCKET=$socket_b
PERSONA_INITIATOR_PID=$initiator_pid
PERSONA_RESPONDER_PID=$responder_pid
PERSONA_PI_MODEL=$pi_model
PERSONA_PI_THINKING=$pi_thinking
PERSONA_WEZTERM_HANDSHAKE=1
EOF
printf '%s\n' "$root" > "$current_file"

initiator_window="$(window_id_for_app_id persona-pty-pi-focus-initiator)"
responder_window="$(window_id_for_app_id persona-pty-pi-focus-responder)"
printf '%s\n' "$initiator_window" > "$root/initiator.niri-window"
printf '%s\n' "$responder_window" > "$root/responder.niri-window"

send_prompt "$socket_a" "You are the initiator Pi harness in a Persona Niri focus test. Print INITIATOR FOCUS READY, then wait idle."
send_prompt "$socket_b" "You are the responder Pi harness in a Persona Niri focus test. Print RESPONDER FOCUS READY, then wait idle."

observe_focus initiator "$initiator_window"
observe_focus responder "$responder_window"
subscribe_focus initiator "$initiator_window"
subscribe_focus responder "$responder_window"

sleep 1
niri msg action focus-window --id "$initiator_window" >/dev/null
sleep 1
niri msg action focus-window --id "$responder_window" >/dev/null
sleep 1
niri msg action focus-window --id "$initiator_window" >/dev/null

wait "$(cat "$root/initiator.focus.pid")" || true
wait "$(cat "$root/responder.focus.pid")" || true

rg --fixed-strings "(FocusObservation (NiriWindow $initiator_window) true" "$root/initiator.focus.log" >/dev/null
rg --fixed-strings "(FocusObservation (NiriWindow $responder_window) true" "$root/responder.focus.log" >/dev/null

echo "pi_niri_focus_test=passed"
echo "root=$root"
echo "initiator_pid=$initiator_pid"
echo "responder_pid=$responder_pid"
echo "initiator_window=$initiator_window"
echo "responder_window=$responder_window"
echo "initiator_focus_log=$root/initiator.focus.log"
echo "responder_focus_log=$root/responder.focus.log"
echo "teardown: PERSONA_PTY_PI_MESSAGE_ROOT=$root nix run .#teardown-pty-pi-message"
