#!/usr/bin/env bash
set -euo pipefail

script="${1:-unknown}"

cat >&2 <<EOF
retired persona-message terminal workflow: $script

This workflow belonged to the retired WezTerm/persona-message local-delivery
path. New terminal harness tests should drive:

  message CLI -> signal-persona-message -> persona-router -> persona-harness -> persona-terminal -> terminal-cell

Use persona-router and persona-terminal Nix apps for the replacement witness.
EOF

exit 64
