#!/usr/bin/env bash

harness_root() {
  if [[ $# -gt 0 && -n "${1:-}" ]]; then
    printf '%s\n' "$1"
    return 0
  fi
  if [[ -n "${PERSONA_MESSAGE_HARNESS_ROOT:-}" ]]; then
    printf '%s\n' "$PERSONA_MESSAGE_HARNESS_ROOT"
    return 0
  fi
  if [[ -s /tmp/persona-message-current ]]; then
    cat /tmp/persona-message-current
    return 0
  fi
  echo "missing harness workspace; pass one or run setup-harnesses first" >&2
  return 2
}

load_harness() {
  local root="$1"
  if [[ ! -f "$root/session.env" ]]; then
    echo "missing session.env in $root" >&2
    return 2
  fi
  # shellcheck disable=SC1090
  source "$root/session.env"
}

send_prompt() {
  local pane="$1"
  local text="$2"
  wezterm cli --prefer-mux send-text --pane-id "$pane" "$text"
  sleep 0.5
  wezterm cli --prefer-mux send-text --pane-id "$pane" --no-paste "$(printf '\r')"
}

require_alive() {
  local name="$1"
  local pid="$2"
  if ! ps -p "$pid" >/dev/null 2>&1; then
    echo "$name harness is not alive: pid $pid" >&2
    return 1
  fi
}
